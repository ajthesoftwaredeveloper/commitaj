{
  "name": "commitaj",
  "version": "1.0.2",
  "description": "A premium, AI-powered CLI tool that stage-analyzes Git changes to generate high-quality commit messages conforming to the Conventional Commits specification.",
  "type": "module",
  "bin": {
    "commitaj": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "tsup --watch --onSuccess \"node dist/index.js\"",
    "build": "tsup",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "git",
    "commit",
    "conventional-commits",
    "cli",
    "openrouter",
    "developer-tools",
    "commit-message",
    "ai-commit",
    "commitaj"
  ],
  "author": "AJ",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ajthesoftwaredeveloper/commitaj.git"
  },
  "bugs": {
    "url": "https://github.com/ajthesoftwaredeveloper/commitaj/issues"
  },
  "homepage": "https://github.com/ajthesoftwaredeveloper/commitaj#readme",
  "dependencies": {
    "@clack/prompts": "^0.10.0",
    "cac": "^7.0.0",
    "conf": "^13.0.0",
    "parse-diff": "^0.12.0",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
